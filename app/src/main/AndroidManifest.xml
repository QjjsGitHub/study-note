<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="com.example.study.broadcast" /> <!-- <uses-permission android:name="android.permission.REAL_GET_TASKS" /> -->
    <permission
        android:name="com.example.study.broadcast"
        android:label="broadcast"
        android:protectionLevel="normal" />
    <permission
        android:name="com.example.study.permission.AIDL_SERVICE"
        android:label="aidl"
        android:protectionLevel="normal" />
    <permission
        android:name="com.example.study.permission.BIND_SERVICE"
        android:label="aidl"
        android:protectionLevel="normal" />
    <!--
        Android 11+ 包可见性声明（必需！）
        如果不添加，会报错：Failed to find provider info
    -->
    <queries>

        <!-- 方式1：通过包名声明要访问的应用 -->
        <!-- <package android:name="com.example.study" /> -->


        <!-- 方式2：通过 provider 的 authorities 声明（更精确） -->
        <provider android:authorities="com.example.study.dataTransform.MyContentProvider" />
    </queries> <!-- 声明隐式意图是图片 -->
    <queries>
        <package android:name="com.example.background" />

        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data android:mimeType="image/png" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.READ_USER_DICTIONARY" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Study"
        tools:targetApi="31">
        <activity
            android:name=".flow.FlowActivity"
            android:exported="false"
            android:label="@string/title_activity_flow"
            android:theme="@style/Theme.Study" />
        <activity
            android:name=".workManager.WorkManagerActivity"
            android:exported="false"
            android:label="@string/title_activity_work_manager"
            android:theme="@style/Theme.Study" />

        <provider
            android:name=".dataTransform.MyContentProvider"
            android:authorities="com.example.study.provider"
            android:exported="true" />

        <activity
            android:name=".dataTransform.DataActivity"
            android:exported="false"
            android:label="@string/title_activity_data"
            android:theme="@style/Theme.Study" />
        <activity
            android:name=".Coroutine.CoroutineActivity"
            android:exported="false"
            android:label="协程"
            android:theme="@style/Theme.Study" />
        <activity
            android:name=".compose.ComposeActivity"
            android:exported="false"
            android:label="@string/title_activity_compose"
            android:theme="@style/Theme.Study" />
        <activity
            android:name=".internet.InternetActivity"
            android:exported="false"
            android:theme="@style/Theme.Study" />
        <activity
            android:name=".recyclerView.RecyclerViewActivity"
            android:exported="false" />
        <activity
            android:name=".Handle.HandleActivity"
            android:exported="false" />

        <receiver
            android:name=".broadcast.BroadcastActivity$MyBroadcastReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.study.broadcast" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".broadcast.BroadcastActivity"
            android:exported="false" />
        <activity
            android:name=".multiThread.ThreadActivity"
            android:exported="false" />

        <service
            android:name=".service.BindService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            android:permission="com.example.study.permission.BIND_SERVICE" />
        <service
            android:name=".service.StartService"
            android:enabled="true"
            android:exported="true"
            android:permission="com.example.study.permission.AIDL_SERVICE"
            android:process=":remote">

            <!--
            <intent-filter>
                <action android:name="com.example.study.StartService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            -->
        </service>

        <activity
            android:name=".service.ServiceActivity"
            android:exported="true" />
        <activity
            android:name=".fragment.FragmentManagerActivity"
            android:exported="false"
            android:label="@string/title_activity_fragment_manager"
            android:theme="@style/Theme.Study.NoActionBar" />
        <activity
            android:name=".fragment.BottomFragmentActivity"
            android:exported="false"
            android:label="@string/title_activity_bottom_fragment" />
        <activity
            android:name=".fragment.FragmentActivity"
            android:exported="false" />
        <activity
            android:name=".activityMode.singleInstancePerTaskActivity"
            android:exported="false"
            android:launchMode="singleInstancePerTask" />
        <activity
            android:name=".activityMode.singleTaskActivity"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name=".activityMode.SingleInstanceActivity"
            android:exported="false"
            android:launchMode="singleInstance" />
        <activity
            android:name=".activityMode.SingleTopActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".activityMode.JavaActivity"
            android:exported="false"
            android:launchMode="standard" />
        <activity
            android:name=".ui.NormalActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Study.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".videoPlayer.VideoPlayerActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Study.NoActionBar" />
    </application>

</manifest>